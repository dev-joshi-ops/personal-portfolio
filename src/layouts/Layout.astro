---
interface Props {
	title: string;
	description?: string;
	canonicalUrl?: string;
	ogImage?: string;
	ogType?: string;
	keywords?: string;
	jsonLd?: Record<string, any> | Record<string, any>[];
}

const {
	title,
	description = "Dev Joshi — DevOps Engineer. Cloud infrastructure, Kubernetes, CI/CD & automation specialist. Available for consulting.",
	canonicalUrl,
	ogImage = "/images/hero-devops.png",
	ogType = "website",
	keywords = "DevOps Engineer, Cloud Infrastructure, Kubernetes, CI/CD, AWS, GCP, Azure, Terraform, Docker, DevOps Portfolio, Site Reliability, Infrastructure as Code, DevOps Consultant, Scalable Automation, Dev Joshi",
	jsonLd,
} = Astro.props;

const siteUrl = "https://dev-joshi.pages.dev";
const currentUrl = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
const fullOgImage = ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`;

// Normalize JSON-LD to array
const jsonLdArray = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<meta name="keywords" content={keywords} />
		<meta name="author" content="Dev Joshi" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		<meta name="google-site-verification" content="mfo8Gb1-h3iqKGtmhlsTgF9q8d0ZoVo3EgnUVcoL57k" />
		<title>{title}</title>
		<link rel="canonical" href={currentUrl} />
		<link rel="sitemap" href="/sitemap-index.xml" />
		<link rel="alternate" hreflang="en" href={currentUrl} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content={ogType} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={fullOgImage} />
		<meta property="og:url" content={currentUrl} />
		<meta property="og:site_name" content="Dev Joshi — DevOps Portfolio" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={fullOgImage} />

		{/* JSON-LD Structured Data */}
		{jsonLdArray.map((ld) => (
			<script type="application/ld+json" set:html={JSON.stringify(ld)} />
		))}
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
        <script is:inline>
            // Check for saved theme preference or system preference
            // Note: For Editorial DevOps, we default to Light mode as per design system focus
            if (localStorage.theme === 'dark') {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
        </script>
        <script src="https://unpkg.com/@studio-freight/lenis@1.0.42/dist/lenis.min.js" defer></script>
        <script is:inline>
            document.addEventListener('DOMContentLoaded', () => {
                const lenis = new Lenis({
                    duration: 0.8,
                    easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
                    direction: 'vertical',
                    gestureDirection: 'vertical',
                    smooth: true,
                    mouseMultiplier: 1,
                    smoothTouch: false,
                    touchMultiplier: 2,
                });

                function raf(time) {
                    lenis.raf(time);
                    requestAnimationFrame(raf);
                }

                requestAnimationFrame(raf);

                // Integrate with Astro's view transitions or standard anchor links if needed
                document.querySelectorAll('a[href^="#"]').forEach(anchor => {
                    anchor.addEventListener('click', function (e) {
                        e.preventDefault();
                        lenis.scrollTo(this.getAttribute('href'));
                    });
                });
            });
        </script>
	</head>
	<body class="bg-editorial-surface text-editorial-text dark:bg-editorial-surface-dark dark:text-editorial-text-dark font-sans antialiased selection:bg-editorial-primary selection:text-white dark:selection:bg-editorial-primary-dark">
		<slot />
	</body>
</html>

<style is:global>
    /* Strictly Square Rule */
    * {
        border-radius: 0 !important;
    }

    /* Offset for fixed navbar when scrolling to sections */
    section[id] {
        scroll-margin-top: 6rem;
    }

    html.lenis {
        height: auto;
    }
    
    .lenis.lenis-smooth {
        scroll-behavior: auto;
    }
    
    .lenis.lenis-smooth [data-lenis-prevent] {
        overscroll-behavior: contain;
    }
    
    .lenis.lenis-stopped {
        overflow: hidden;
    }
    
    .lenis.lenis-scrolling iframe {
        pointer-events: none;
    }
    
    html.is-transitioning *,
    html.is-transitioning *::before,
    html.is-transitioning *::after {
        transition: none !important;
    }

	body {
        transition: background-color 0.5s cubic-bezier(0.25, 0.8, 0.25, 1), color 0.5s cubic-bezier(0.25, 0.8, 0.25, 1);
    }

    /* Smooth theme transition for all elements */
    *, *::before, *::after {
        transition-property: background-color, border-color, color, fill, stroke;
        transition-timing-function: cubic-bezier(0.25, 0.1, 0.25, 1);
        transition-duration: 300ms;
    }

	/* Custom Scrollbar */
	::-webkit-scrollbar {
		width: 10px;
	}
	::-webkit-scrollbar-track {
		background: #fcf9f8;
	}
    :global(.dark) ::-webkit-scrollbar-track {
        background: #0f0f0f;
    }
	::-webkit-scrollbar-thumb {
		background: #e4e2e2;
	}
    :global(.dark) ::-webkit-scrollbar-thumb {
        background: #2d2d2d;
    }
	::-webkit-scrollbar-thumb:hover {
		background: #4d44e3;
	}
    :global(.dark) ::-webkit-scrollbar-thumb:hover {
        background: #7c73ff;
    }
</style>
