---
import Layout from './Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const { frontmatter } = Astro.props;

const siteUrl = "https://dev-joshi.pages.dev";
const articleUrl = new URL(Astro.url.pathname, siteUrl).href;

// Article Schema — enables article rich results
const articleSchema = {
	"@context": "https://schema.org",
	"@type": "Article",
	"headline": frontmatter.title,
	"description": frontmatter.description,
	"image": frontmatter.image ? `${siteUrl}${frontmatter.image}` : `${siteUrl}/images/hero-devops.png`,
	"author": {
		"@type": "Person",
		"name": frontmatter.author || "Dev Joshi",
		"url": siteUrl
	},
	"publisher": {
		"@type": "Person",
		"name": "Dev Joshi",
		"url": siteUrl
	},
	"datePublished": frontmatter.date,
	"url": articleUrl,
	"mainEntityOfPage": articleUrl,
	"keywords": frontmatter.tags?.join(", ") || ""
};

// BreadcrumbList Schema
const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{
			"@type": "ListItem",
			"position": 1,
			"name": "Home",
			"item": siteUrl
		},
		{
			"@type": "ListItem",
			"position": 2,
			"name": "Blog",
			"item": `${siteUrl}/blog`
		},
		{
			"@type": "ListItem",
			"position": 3,
			"name": frontmatter.title,
			"item": articleUrl
		}
	]
};
---

<Layout
  title={`${frontmatter.title} | Dev Joshi`}
  description={frontmatter.description}
  ogImage={frontmatter.image || "/images/hero-devops.png"}
  ogType="article"
  keywords={frontmatter.tags?.join(", ") || undefined}
  jsonLd={[articleSchema, breadcrumbSchema]}
>
  <Navbar />
  <main class="pt-24 pb-16 bg-editorial-surface dark:bg-editorial-surface-dark transition-colors duration-500">
    <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Back and Actions Bar -->
      <div class="flex items-center justify-between py-6 border-b border-editorial-surface-highest dark:border-editorial-surface-highest-dark mb-12">
        <a href="/blog" class="flex items-center gap-2 text-editorial-secondary dark:text-editorial-secondary-dark hover:text-editorial-primary dark:hover:text-editorial-primary-dark transition-colors group font-mono text-xs uppercase tracking-widest">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-1 transition-transform"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
            <span>Back to Index</span>
        </a>
        
        <div class="flex items-center gap-4">
            <button id="share-btn" class="text-editorial-secondary dark:text-editorial-secondary-dark hover:text-editorial-primary dark:hover:text-editorial-primary-dark transition-colors p-2 border border-editorial-surface-highest dark:border-editorial-surface-highest-dark hover:bg-editorial-surface-highest dark:hover:bg-editorial-surface-highest-dark" aria-label="Share">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" x2="15.42" y1="13.51" y2="17.49"/><line x1="15.41" x2="8.59" y1="6.51" y2="10.49"/></svg>
            </button>
        </div>
      </div>

      <header class="mb-12 text-left">
        <div class="flex items-center justify-start gap-4 font-mono text-xs uppercase tracking-widest text-editorial-secondary dark:text-editorial-secondary-dark mb-6">
          <span class="text-editorial-primary dark:text-editorial-primary-dark font-bold">{frontmatter.category || 'Tech'}</span>
          <span>/</span>
          <span><time datetime={frontmatter.date}>{frontmatter.date}</time></span>
          <span>/</span>
          <span>{frontmatter.readTime}</span>
        </div>
        <h1 class="text-4xl md:text-6xl font-bold text-editorial-text dark:text-editorial-text-dark mb-8 tracking-tight font-serif leading-[1.1]">{frontmatter.title}</h1>
        <div class="flex items-center justify-start gap-4 py-6 border-y border-editorial-surface-highest dark:border-editorial-surface-highest-dark">
            <div class="w-12 h-12 bg-editorial-surface-highest dark:bg-editorial-surface-highest-dark flex items-center justify-center grayscale">
                <!-- User Icon or Initials -->
                <span class="font-mono text-lg font-bold text-editorial-secondary dark:text-editorial-secondary-dark">{frontmatter.author.split(' ').map(n => n[0]).join('')}</span>
            </div>
            <div class="text-left">
                <p class="font-mono text-xs uppercase tracking-widest font-bold text-editorial-text dark:text-editorial-text-dark">{frontmatter.author}</p>
                <p class="font-mono text-[10px] uppercase tracking-widest text-editorial-secondary dark:text-editorial-secondary-dark">Lead DevOps Architect</p>
            </div>
        </div>
      </header>

      <div class="blog-content prose prose-lg prose-slate dark:prose-invert max-w-none font-sans text-editorial-text dark:text-editorial-text-dark leading-relaxed">
        <slot />
      </div>

      <!-- Footer CTA -->
      <div class="mt-16 pt-12 border-t border-editorial-surface-highest dark:border-editorial-surface-highest-dark">
        <a href="https://tinyurl.com/devjoshimedium" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-3 p-6 transition-all group bg-editorial-text dark:bg-editorial-primary-dark text-editorial-surface dark:text-editorial-surface-dark hover:bg-editorial-primary dark:hover:bg-editorial-text-dark font-mono text-xs uppercase tracking-widest">
            <span>Read more articles on</span>
            <span class="font-bold flex items-center gap-1 underline underline-offset-4">
                Medium
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
            </span>
        </a>
      </div>
    </article>
  </main>
  <Footer />
</Layout>

<script>
    const shareBtn = document.getElementById('share-btn');
    
    if (shareBtn) {
        shareBtn.addEventListener('click', async () => {
            const originalIcon = shareBtn.innerHTML;
            const successIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-500"><polyline points="20 6 9 17 4 12"/></svg>`;
            
            const showSuccess = () => {
                shareBtn.innerHTML = successIcon;
                shareBtn.classList.add('border-green-500/50');
                setTimeout(() => {
                    shareBtn.innerHTML = originalIcon;
                    shareBtn.classList.remove('border-green-500/50');
                }, 2000);
            };

            if (navigator.share) {
                try {
                    await navigator.share({
                        title: document.title,
                        text: `Check out this article: ${document.title}`,
                        url: window.location.href
                    });
                    showSuccess();
                } catch (err) {
                    if ((err as Error).name !== 'AbortError') {
                        console.error('Error sharing:', err);
                    }
                }
            } else {
                try {
                    await navigator.clipboard.writeText(window.location.href);
                    showSuccess();
                } catch (err) {
                    console.error('Failed to copy:', err);
                }
            }
        });
    }
</script>

<script>
    // Inject copy buttons into code blocks
    document.querySelectorAll('.blog-content pre').forEach(pre => {

        const btn = document.createElement('button');
        btn.className = 'copy-btn';
        btn.setAttribute('aria-label', 'Copy code');
        btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="0"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>`;

        btn.addEventListener('click', async () => {
            const code = pre.querySelector('code')?.textContent || pre.textContent;
            try {
                await navigator.clipboard.writeText(code);
                btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
                btn.classList.add('copied');
                setTimeout(() => {
                    btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="0"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>`;
                    btn.classList.remove('copied');
                }, 2000);
            } catch (err) {
                console.error('Copy failed:', err);
            }
        });

        pre.appendChild(btn);
    });
</script>
<style is:global>
  /* ===== Blog Content Styling ===== */

  /* Headings */
  .blog-content h1,
  .blog-content h2,
  .blog-content h3,
  .blog-content h4 {
    font-family: 'Newsreader', Georgia, serif;
    color: #323232;
    letter-spacing: -0.02em;
  }
  .dark .blog-content h1,
  .dark .blog-content h2,
  .dark .blog-content h3,
  .dark .blog-content h4 {
    color: #efefef;
  }

  /* Links */
  .blog-content a {
    color: #4d44e3;
    text-decoration: none;
  }
  .blog-content a:hover {
    text-decoration: underline;
  }
  .dark .blog-content a {
    color: #7c73ff;
  }

  /* Strong */
  .blog-content strong {
    color: #323232;
    font-weight: 700;
  }
  .dark .blog-content strong {
    color: #efefef;
  }

  /* Inline code */
  .blog-content :not(pre) > code {
    font-family: 'JetBrains Mono', monospace;
    background-color: #f0eded;
    color: #323232;
    padding: 2px 6px;
    font-size: 0.85em;
    border: 1px solid #e4e2e2;
  }
  .dark .blog-content :not(pre) > code {
    background-color: #1a1a1a;
    color: #efefef;
    border-color: #2d2d2d;
  }

  /* Code blocks */
  .blog-content pre {
    background-color: #1a1a1a !important;
    color: #e0e0e0 !important;
    padding: 1.5rem 2rem;
    overflow-x: auto;
    border: 1px solid #2d2d2d;
    margin: 1.5rem 0;
    font-size: 0.875rem;
    line-height: 1.7;
  }
  .dark .blog-content pre {
    background-color: #111111 !important;
    border-color: #2d2d2d;
  }

  .blog-content pre code {
    background: none !important;
    border: none !important;
    padding: 0 !important;
    font-family: 'JetBrains Mono', monospace;
    font-size: inherit;
    color: inherit !important;
  }

  /* Remove any per-line background highlights from syntax highlighter */
  .blog-content pre code .line,
  .blog-content pre code span {
    background: none !important;
  }

  /* Images */
  .blog-content img {
    border: 1px solid #e4e2e2;
    margin: 2rem 0;
  }
  .dark .blog-content img {
    border-color: #2d2d2d;
  }

  /* Blockquotes */
  .blog-content blockquote {
    border-left: 3px solid #4d44e3;
    padding-left: 1.25rem;
    font-style: italic;
    color: #585f6d;
  }
  .dark .blog-content blockquote {
    border-left-color: #7c73ff;
    color: #a1a1a1;
  }

  /* Lists */
  .blog-content ul,
  .blog-content ol {
    padding-left: 1.5rem;
  }
  .blog-content li::marker {
    color: #4d44e3;
  }
  .dark .blog-content li::marker {
    color: #7c73ff;
  }

  /* Horizontal rules */
  .blog-content hr {
    border-color: #e4e2e2;
  }
  .dark .blog-content hr {
    border-color: #2d2d2d;
  }
  /* Code block needs relative for copy button */
  .blog-content pre {
    position: relative !important;
  }

  /* Copy button */
  .copy-btn {
    position: absolute !important;
    top: 0.5rem;
    right: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    padding: 0;
    color: #888;
    background: #2a2a2a;
    border: 1px solid #444;
    cursor: pointer;
    opacity: 0.7;
    transition: opacity 0.2s, color 0.2s, background-color 0.2s, border-color 0.2s;
    z-index: 10;
  }

  /* Desktop: hide until hover */
  @media (min-width: 769px) {
    .copy-btn {
      opacity: 0;
    }
    .blog-content pre:hover .copy-btn {
      opacity: 1;
    }
  }

  .copy-btn:hover {
    color: #fff;
    background: #3a3a3a;
    border-color: #666;
  }
  .copy-btn.copied {
    color: #4ade80;
    border-color: #4ade80;
    opacity: 1;
  }
</style>

