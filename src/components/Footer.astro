---
import { resume } from '../data/resume';

const currentYear = new Date().getFullYear();
const { pathname } = Astro.url;
const isHome = pathname === '/';
---

<footer class="bg-editorial-text dark:bg-editorial-surface-highest-dark pt-24 pb-12 transition-colors duration-500">
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row justify-between gap-24">
      
      <!-- Brand Column -->
      <div class="lg:w-1/2 space-y-8">
        <div class="flex items-center gap-4">
            <span class=" text-3xl font-bold  text-editorial-surface dark:text-editorial-text-dark tracking-tighter">
              Dev Joshi
            </span>
        </div>
        <p class="text-editorial-primary dark:text-editorial-primary-dark font-mono text-sm uppercase tracking-[0.2em] font-bold">
          Ship it. Scale it. Secure it.
        </p>
        <div class="flex gap-4 pt-4">
            <a href={resume.basics.profiles?.find(p => p.network === 'LinkedIn')?.url || '#'} target="_blank" rel="noopener noreferrer" class="w-12 h-12 bg-editorial-surface-low dark:bg-editorial-surface-low-dark flex items-center justify-center text-editorial-text dark:text-editorial-text-dark hover:bg-editorial-primary dark:hover:bg-editorial-primary-dark hover:text-editorial-surface dark:hover:text-editorial-surface-dark transition-all duration-300" aria-label="LinkedIn">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
            <a href={resume.basics.profiles?.find(p => p.network === 'GitHub')?.url || '#'} target="_blank" rel="noopener noreferrer" class="w-12 h-12 bg-editorial-surface-low dark:bg-editorial-surface-low-dark flex items-center justify-center text-editorial-text dark:text-editorial-text-dark hover:bg-editorial-primary dark:hover:bg-editorial-primary-dark hover:text-editorial-surface dark:hover:text-editorial-surface-dark transition-all duration-300" aria-label="GitHub">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
            </a>
            <a href={`mailto:${resume.basics.email}`} class="w-12 h-12 bg-editorial-surface-low dark:bg-editorial-surface-low-dark flex items-center justify-center text-editorial-text dark:text-editorial-text-dark hover:bg-editorial-primary dark:hover:bg-editorial-primary-dark hover:text-editorial-surface dark:hover:text-editorial-surface-dark transition-all duration-300" aria-label="Email">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </a>
        </div>
      </div>

      <!-- Right Side: Links -->
      <div class="grid grid-cols-2 gap-12 lg:gap-32">
          <div>
            <h3 class="text-editorial-primary dark:text-editorial-primary-dark font-mono text-[10px] uppercase tracking-[0.3em] font-bold mb-8">Navigation</h3>
            <ul class="space-y-4 font-mono text-[11px] uppercase tracking-widest">
                <li><a href={isHome ? "#about" : "/#about"} class="text-editorial-surface-highest dark:text-editorial-secondary-dark hover:text-editorial-primary dark:hover:text-editorial-primary-dark transition-colors">/ Background</a></li>
                <li><a href={isHome ? "#projects" : "/#projects"} class="text-editorial-surface-highest dark:text-editorial-secondary-dark hover:text-editorial-primary dark:hover:text-editorial-primary-dark transition-colors">/ Project Archives</a></li>
                <li><a href={isHome ? "#stack" : "/#stack"} class="text-editorial-surface-highest dark:text-editorial-secondary-dark hover:text-editorial-primary dark:hover:text-editorial-primary-dark transition-colors">/ Technical Stack</a></li>
                <li><a href="/open-source" class="text-editorial-surface-highest dark:text-editorial-secondary-dark hover:text-editorial-primary dark:hover:text-editorial-primary-dark transition-colors">/ Open Source</a></li>
                <li><a href="mailto:joshid647@gmail.com" class="text-editorial-surface-highest dark:text-editorial-secondary-dark hover:text-editorial-primary dark:hover:text-editorial-primary-dark transition-colors">/ Inquiries</a></li>
            </ul>
          </div>

          <div>
            <h3 class="text-editorial-primary dark:text-editorial-primary-dark font-mono text-[10px] uppercase tracking-[0.3em] font-bold mb-8">Operational Focus</h3>
             <ul class="space-y-4 font-mono text-[11px] uppercase tracking-widest">
                <li class="text-editorial-surface-highest dark:text-editorial-secondary-dark">Cloud Topologies</li>
                <li class="text-editorial-surface-highest dark:text-editorial-secondary-dark">CI/CD Orchestration</li>
                <li class="text-editorial-surface-highest dark:text-editorial-secondary-dark">SRE Methodologies</li>
                <li class="text-editorial-surface-highest dark:text-editorial-secondary-dark">Security Governance</li>
            </ul>
          </div>
      </div>
    </div>

  </div>
</footer>
