---
import { resume } from '../data/resume';
---

<section id="home" class="min-h-screen flex items-center pt-20 relative overflow-hidden">
  <!-- Background Elements -->
  <div class="absolute top-0 left-0 w-full h-full overflow-hidden -z-10">
      <div class="absolute top-[-10%] right-[-5%] w-[500px] h-[500px] bg-primary/10 dark:bg-primary/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-[-10%] left-[-10%] w-[600px] h-[600px] bg-slate-200/50 dark:bg-navy-800/50 rounded-full blur-3xl"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      
      <!-- Left Column: Text -->
      <div class="space-y-8">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white dark:bg-navy-800 border border-slate-200 dark:border-white/10 shadow-sm">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
          </span>
          <span class="text-xs font-medium text-slate-600 dark:text-primary tracking-wide">Open to Work</span>
        </div>

        <!-- Headline -->
        <div class="space-y-2">
            <h1 class="text-5xl md:text-7xl font-bold text-slate-900 dark:text-white tracking-tight leading-tight">
            Automating the <br />
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-sky-400">Future of Cloud.</span>
            </h1>
        </div>
        
        <!-- Subtext -->
        <p class="text-lg text-slate-600 dark:text-slate-400 max-w-xl leading-relaxed">
          Hi, I'm <strong class="text-slate-900 dark:text-white">{resume.basics.name}</strong>. {resume.basics.summary.split('.')[0]}.
          Building resilient infrastructure, scalable CI/CD pipelines, and secure cloud environments.
        </p>

        <!-- Buttons -->
        <div class="flex flex-wrap gap-4">
          <a 
            href="#projects"
            class="px-8 py-4 bg-navy-900 dark:bg-white text-white dark:text-navy-900 font-bold rounded-lg hover:bg-navy-800 dark:hover:bg-slate-200 transition-all transform hover:-translate-y-1 shadow-lg shadow-navy-900/20 dark:shadow-white/5"
          >
            View Work &darr;
          </a>
          <a 
            href={resume.basics.url || "#"}
            class="px-8 py-4 bg-white dark:bg-navy-800 border border-slate-200 dark:border-white/10 text-slate-700 dark:text-white font-medium rounded-lg hover:bg-slate-50 dark:hover:bg-navy-700 transition-all flex items-center gap-2 shadow-sm"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-download"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
            Download CV
          </a>
        </div>

        <!-- Socials -->
        <div class="flex items-center gap-6 pt-4">
            <a href={resume.basics.profiles?.find(p => p.network === 'LinkedIn')?.url} target="_blank" class="text-slate-400 hover:text-navy-900 dark:hover:text-white transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-linkedin"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
        </div>
      </div>

      <!-- Right Column: Image -->
      <div class="relative hidden lg:block">
        <div class="relative z-10 rounded-2xl overflow-hidden border border-white/10 shadow-2xl bg-navy-800 aspect-square flex items-center justify-center group">
            <!-- Placeholder for Image -->
            <div class="absolute inset-0 bg-gradient-to-br from-navy-800 to-navy-900"></div>
            <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-white/20 group-hover:text-white/30 transition-colors"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            
            <!-- Floating Card -->
            <div class="absolute bottom-8 left-8 bg-navy-900/90 backdrop-blur-md p-4 rounded-xl border border-white/10 shadow-xl flex items-center gap-4">
                <div class="h-12 w-12 rounded-full bg-green-500/20 flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-500"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                </div>
                <div>
                    <p class="text-xs text-slate-400 font-medium uppercase tracking-wider">Uptime</p>
                    <p class="text-xl font-bold text-white">99.99%</p>
                </div>
            </div>

             <!-- Floating Card 2 -->
             <div class="absolute top-8 right-8 bg-navy-900/90 backdrop-blur-md p-4 rounded-xl border border-white/10 shadow-xl flex items-center gap-4">
                <div class="h-10 w-10 rounded-full bg-primary/20 flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
                </div>
                <div>
                    <p class="text-xs text-slate-400 font-medium uppercase tracking-wider">Certified</p>
                    <p class="text-sm font-bold text-white">AWS Architect</p>
                </div>
            </div>
        </div>
        
        <!-- Decorative Blob behind image -->
        <div class="absolute -inset-4 bg-gradient-to-r from-primary to-purple-600 rounded-2xl opacity-20 blur-2xl -z-10"></div>
      </div>
    </div>
  </div>
</section>
