---
import { resume } from '../data/resume';

const categories = ["All", "Cloud", "DevOps"];

// Reorder and modify projects
let projects = [...resume.projects];
const targetProjectName = "Cloud Architecture & Cost Optimization";
const targetIndex = projects.findIndex(p => p.name === targetProjectName);

if (targetIndex > -1) {
  const targetProject = { ...projects[targetIndex] };
  // Update description
  targetProject.description = "Achieved 100% cost reduction on external DB dependencies and implemented automated scale-down policies, significantly improving cost-efficiency for a major finance client.";
  
  // Remove from current position
  projects.splice(targetIndex, 1);
  // Add to front
  projects.unshift(targetProject);
}
---

<section id="projects" class="py-24 bg-slate-50 dark:bg-navy-900 transition-colors duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
      <div>
        <h2 class="text-3xl md:text-5xl font-bold text-slate-900 dark:text-white mb-4 tracking-tight">Featured Projects</h2>
        <p class="text-slate-600 dark:text-slate-400 text-lg">Real-world infrastructure and automation challenges I've solved.</p>
      </div>
      
      <!-- Filter Pills -->
      <div class="flex flex-wrap gap-2" id="project-filters">
        {categories.map((cat, index) => (
          <button 
            data-filter={cat === "All" ? "all" : cat === "CI/CD" ? "cicd" : cat.toLowerCase()}
            class={`filter-btn px-4 py-2 rounded-full text-sm font-medium transition-all ${index === 0 ? 'bg-primary text-white shadow-lg shadow-primary/25 active' : 'bg-white dark:bg-navy-800 text-slate-600 dark:text-slate-400 hover:text-primary dark:hover:text-white hover:bg-slate-50 dark:hover:bg-navy-700 border border-slate-200 dark:border-white/5'}`}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="projects-grid">
      {projects.map((project) => {
        const isRoiProject = project.name === "Cloud Architecture & Cost Optimization";
        return (
        <div class="project-card group bg-white dark:bg-navy-800 rounded-2xl overflow-hidden border border-slate-200 dark:border-white/5 hover:border-primary/30 transition-all duration-300 shadow-lg shadow-slate-200/50 dark:shadow-none hover:shadow-2xl hover:shadow-primary/5 flex flex-col" data-category={project.category}>
          
          <!-- Image Container -->
          <div class="relative h-48 overflow-hidden">
            <div class="absolute inset-0 bg-navy-900/20 group-hover:bg-transparent transition-colors z-10"></div>
            <img 
              src={project.image} 
              alt={`${project.name} — project screenshot`} 
              loading="lazy"
              class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-500"
            />
            
            {isRoiProject && (
                <div class="absolute top-4 right-4 z-30">
                    <div class="bg-lime-400 text-navy-900 text-sm font-extrabold px-4 py-1.5 rounded-full shadow-lg shadow-lime-400/20 flex items-center gap-1 transform hover:scale-105 transition-transform">
                        <span>$$$ SAVED</span>
                    </div>
                </div>
            )}

            <div class={`absolute top-4 ${isRoiProject ? 'left-4' : 'right-4'} z-20`}>
              <span class="px-3 py-1 bg-white/90 dark:bg-navy-900/90 backdrop-blur-md text-xs font-mono text-slate-900 dark:text-white rounded-full border border-slate-200 dark:border-white/10 shadow-sm">
                {project.category}
              </span>
            </div>
          </div>

          <!-- Content -->
          <div class="p-6 flex flex-col flex-grow">
            <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-3 group-hover:text-primary transition-colors">
              {project.name}
            </h3>
            
            <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed mb-6 flex-grow">
              {project.description}
            </p>

            <!-- Tags -->
            <div class="flex flex-wrap gap-2 mb-6">
               {project.tags.map(tag => (
                   <span class="px-2 py-1 bg-slate-100 dark:bg-navy-900 rounded text-xs font-medium text-slate-600 dark:text-slate-300 border border-slate-200 dark:border-white/5">
                      {tag}
                   </span>
               ))}
            </div>

            <!-- CTA -->
            <a 
                href={`/projects/${project.name.toLowerCase().replace(/ /g, '-').replace(/[^\w-]+/g, '')}`} 
                class={`w-full py-3 rounded-xl border text-sm font-medium transition-all text-center group-hover:border-primary/30 ${
                    isRoiProject 
                    ? 'bg-primary/10 border-primary text-primary hover:bg-primary hover:text-white shadow-lg shadow-primary/20' 
                    : 'border-slate-200 dark:border-white/10 text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-white hover:text-primary dark:hover:text-navy-900'
                }`}
            >
              {project.cta}
            </a>
          </div>
        </div>
      )})}
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filters = document.querySelectorAll('.filter-btn');
    const projects = document.querySelectorAll('.project-card');

    filters.forEach(btn => {
      btn.addEventListener('click', () => {
        // Remove active class from all
        filters.forEach(f => {
            f.classList.remove('bg-primary', 'text-white', 'shadow-lg', 'shadow-primary/25', 'active');
            f.classList.add('bg-white', 'dark:bg-navy-800', 'text-slate-600', 'dark:text-slate-400', 'hover:text-primary', 'dark:hover:text-white', 'hover:bg-slate-50', 'dark:hover:bg-navy-700', 'border', 'border-slate-200', 'dark:border-white/5');
        });

        // Add active class to clicked
        btn.classList.remove('bg-white', 'dark:bg-navy-800', 'text-slate-600', 'dark:text-slate-400', 'hover:text-primary', 'dark:hover:text-white', 'hover:bg-slate-50', 'dark:hover:bg-navy-700', 'border', 'border-slate-200', 'dark:border-white/5');
        btn.classList.add('bg-primary', 'text-white', 'shadow-lg', 'shadow-primary/25', 'active');

        const filterValue = btn.getAttribute('data-filter');

        projects.forEach(project => {
            const category = (project as HTMLElement).dataset.category;
            if (filterValue === 'all' || category === filterValue) {
                (project as HTMLElement).style.display = 'flex';
                // Add a small animation or fade-in could go here
            } else {
                (project as HTMLElement).style.display = 'none';
            }
        });
      });
    });
  });
</script>
