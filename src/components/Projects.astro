---
import { resume } from '../data/resume';

const categories = ["All", "Cloud", "Devops"];

// Reorder and modify projects
let projects = [...resume.projects];
const targetProjectName = "Cloud Architecture & Cost Optimization";
const targetIndex = projects.findIndex(p => p.name === targetProjectName);

if (targetIndex > -1) {
  const targetProject = { ...projects[targetIndex] };
  targetProject.description = "Enterprise cloud infrastructure redesign";
  projects.splice(targetIndex, 1);
  projects.unshift(targetProject);
}

// Ensure Devops casing
projects = projects.map(p => ({
  ...p,
  category: p.category === "DevOps" ? "Devops" : p.category
}));
---

<section id="projects" class="py-20 bg-editorial-surface dark:bg-editorial-surface-dark">
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end mb-16 gap-12">
      <div class="max-w-2xl">
        <h2 class="sr-only">DevOps Projects & Case Studies</h2>
        <h2 aria-hidden="true" class="text-4xl md:text-6xl font-bold text-editorial-text dark:text-editorial-text-dark mb-6 tracking-tight   border-l-4 border-editorial-primary dark:border-editorial-primary-dark pl-8">Project Archives</h2>
        <p class="text-editorial-secondary dark:text-editorial-secondary-dark text-xl  font-light leading-relaxed">A documented record of infrastructure engineering and operational automation across various cloud topologies.</p>
      </div>
      
      <!-- Filter Tabs -->
      <div class="flex flex-wrap gap-x-8 gap-y-4 relative pb-2" id="project-filters-container">
        {categories.map((cat, index) => (
          <button 
            data-filter={cat.toLowerCase()}
            class={`filter-btn  text-[15px] transition-all relative pb-2 group ${index === 0 ? 'active text-editorial-text dark:text-editorial-text-dark font-medium' : 'text-[#999] dark:text-editorial-secondary-dark hover:text-editorial-text'}`}
          >
            {cat}
            {/* Per-tab indicator for robust multi-line support */}
            <div class="absolute bottom-[-1px] left-0 h-[2.5px] bg-black dark:bg-white transition-all duration-300 ease-[cubic-bezier(0.4,0,0.2,1)] w-0 opacity-0 group-[.active]:w-full group-[.active]:opacity-100"></div>
          </button>
        ))}
      </div>
    </div>
  </div>

  <div class="max-w-screen-2xl mx-auto">
    <!-- Project Grid (Gap-px logic with bleed-to-edge borders on mobile) -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-[#f0f0f0] dark:bg-editorial-surface-highest-dark overflow-hidden md:px-0" id="projects-grid">
      {projects.map((project) => {
        const slug = project.name.toLowerCase().replace(/ /g, '-').replace(/[^\w-]+/g, '');
        return (
          <div 
            class="project-card group bg-editorial-surface dark:bg-editorial-surface-dark transition-all duration-300 flex flex-col" 
            data-category={project.category}
          >
            <a href={`/projects/${slug}`} class="block py-16 px-6 md:px-12 flex flex-col h-full group-hover:bg-[#fcfcfc] dark:group-hover:bg-editorial-surface-low-dark transition-colors">
              <h3 class="text-3xl font-bold text-editorial-text dark:text-editorial-text-dark   mb-4 group-hover:text-editorial-primary dark:group-hover:text-editorial-primary-dark transition-colors">
                {project.name}
              </h3>
              
              <p class="text-editorial-secondary dark:text-editorial-secondary-dark text-[17px]  font-light mb-8 leading-relaxed">
                {project.description}
              </p>

              <!-- Tags -->
              <div class="flex flex-wrap gap-x-4 gap-y-1 mb-8">
                {project.tags.slice(0, 3).map(tag => (
                  <span class="text-[13px]  text-[#aaa] dark:text-editorial-secondary-dark font-light">
                    {tag}
                  </span>
                ))}
              </div>

              <!-- View Link -->
              <div class="flex items-center gap-2 text-[15px]  font-medium text-editorial-text dark:text-editorial-text-dark mt-auto group-hover:gap-3 transition-all group-hover:text-editorial-primary dark:group-hover:text-editorial-primary-dark">
                View Case Study 
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
              </div>
            </a>
          </div>
        )
      })}
      <!-- Filler div for odd counts -->
      <div id="project-filler" class="hidden md:block bg-editorial-surface dark:bg-editorial-surface-dark"></div>
    </div>
  </div>
</section>

<script>
  function setupProjectFilters() {
    const filters = document.querySelectorAll('.filter-btn');
    const projects = document.querySelectorAll('.project-card');
    const indicator = document.getElementById('project-indicator');
    const filler = document.getElementById('project-filler');

    function updateIndicator(btn) {
      // Logic handled via Tailwind group classes for mobile robustness
    }

    function updateFillerVisibility() {
        if (!filler) return;
        const visibleProjects = Array.from(projects).filter(p => (p as HTMLElement).style.display !== 'none');
        if (visibleProjects.length % 2 !== 0) {
            filler.style.display = 'block';
        } else {
            filler.style.display = 'none';
        }
    }

    // Initialize
    const initialActive = document.querySelector('.filter-btn.active');
    if (initialActive) updateIndicator(initialActive as HTMLElement);
    updateFillerVisibility();

    filters.forEach(btn => {
      btn.addEventListener('click', () => {
        const filterValue = btn.getAttribute('data-filter');

        filters.forEach(f => {
          f.classList.remove('active', 'text-editorial-text', 'dark:text-editorial-text-dark', 'font-medium');
          f.classList.add('text-[#999]', 'dark:text-editorial-secondary-dark');
        });

        btn.classList.add('active', 'text-editorial-text', 'dark:text-editorial-text-dark', 'font-medium');
        btn.classList.remove('text-[#999]', 'dark:text-editorial-secondary-dark');
        
        updateIndicator(btn as HTMLElement);

        projects.forEach(project => {
          const category = (project as HTMLElement).dataset.category;
          if (filterValue === 'all' || category?.toLowerCase() === filterValue?.toLowerCase()) {
            (project as HTMLElement).style.display = 'flex';
          } else {
            (project as HTMLElement).style.display = 'none';
          }
        });

        updateFillerVisibility();
      });
    });

    window.addEventListener('resize', () => {
      const activeBtn = document.querySelector('.filter-btn.active');
      if (activeBtn) updateIndicator(activeBtn as HTMLElement);
    });
  }

  setupProjectFilters();
  document.addEventListener('astro:after-swap', setupProjectFilters);
</script>
