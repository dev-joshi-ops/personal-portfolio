---
const faqs = [
  {
    question: "Are you available for full-time roles or just consulting?",
    answer: "I am currently open to both freelance consulting contracts and high-impact full-time opportunities. My ideal role involves cloud architecture design, Kubernetes orchestration, or leading DevOps transformations.",
    isOpen: true
  },
  {
    question: "What is your primary tech stack?",
    answer: "My core stack includes AWS/Azure, Kubernetes, Terraform, Docker, and CI/CD pipelines using GitHub Actions or Jenkins. I'm also proficient in Python and Go for automation.",
    isOpen: false
  },
  {
    question: "Do you offer infrastructure audits?",
    answer: "Yes, I conduct comprehensive infrastructure audits to identify security vulnerabilities, cost optimization opportunities, and performance bottlenecks.",
    isOpen: false
  },
  {
    question: "Can you work with legacy on-prem systems?",
    answer: "Absolutely. I have extensive experience modernizing legacy systems and migrating on-premise infrastructure to the cloud using hybrid approaches.",
    isOpen: false
  }
];
---

<section id="faq" class="py-20 bg-editorial-surface dark:bg-editorial-surface-dark border-t border-editorial-surface-highest dark:border-editorial-surface-highest-dark">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="sr-only">Frequently Asked Questions</h2>
    <h2 aria-hidden="true" class="text-4xl md:text-6xl font-bold text-left text-editorial-text dark:text-editorial-text-dark mb-16 tracking-tight   border-l-4 border-editorial-primary dark:border-editorial-primary-dark pl-8">
      Common Inquiries
    </h2>

    <div class="space-y-0 border-t border-editorial-surface-highest dark:border-editorial-surface-highest-dark">
      {faqs.map((faq, index) => (
        <div class="faq-item group border-b border-editorial-surface-highest dark:border-editorial-surface-highest-dark">
          <button
            class="w-full flex items-center justify-between p-8 text-left bg-editorial-surface dark:bg-editorial-surface-dark hover:bg-editorial-surface-low dark:hover:bg-editorial-surface-low-dark transition-all duration-500 focus:outline-none"
            aria-expanded={faq.isOpen}
            aria-controls={`faq-answer-${index}`}
          >
            <span class="text-xl md:text-2xl font-bold text-editorial-text dark:text-editorial-text-dark group-hover:text-editorial-primary dark:group-hover:text-editorial-primary-dark transition-colors  ">
              {faq.question}
            </span>
            <span class="ml-6 flex-shrink-0 text-editorial-primary dark:text-editorial-primary-dark">
              <svg 
                class={`w-5 h-5 transform transition-transform duration-500 ${faq.isOpen ? 'rotate-180' : ''} icon-chevron`} 
                fill="none" 
                viewBox="0 0 24 24" 
                stroke="currentColor"
                stroke-width="1.5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </span>
          </button>
          <div 
            id={`faq-answer-${index}`}
            class={`overflow-hidden transition-all duration-500 ease-in-out ${faq.isOpen ? 'max-h-[500px] opacity-100' : 'max-h-0 opacity-0'}`}
          >
            <div class="p-12 pt-0 text-editorial-secondary dark:text-editorial-secondary-dark text-lg  font-light leading-relaxed bg-editorial-surface-low dark:bg-editorial-surface-low-dark  border-t border-editorial-surface-highest/10 dark:border-editorial-surface-highest-dark/10">
              <div class="pt-8">
                {faq.answer}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const faqItems = document.querySelectorAll('.faq-item');

    faqItems.forEach(item => {
      const button = item.querySelector('button');
      const answer = item.querySelector('div[id^="faq-answer-"]');
      const icon = item.querySelector('.icon-chevron');

      button.addEventListener('click', () => {
        const isExpanded = button.getAttribute('aria-expanded') === 'true';
        
        button.setAttribute('aria-expanded', !isExpanded);
        
        if (!isExpanded) {
            answer.classList.remove('max-h-0', 'opacity-0');
            answer.classList.add('max-h-[500px]', 'opacity-100');
            icon.classList.add('rotate-180');
            button.classList.add('bg-editorial-surface-low', 'dark:bg-editorial-surface-low-dark');
        } else {
            answer.classList.add('max-h-0', 'opacity-0');
            answer.classList.remove('max-h-[500px]', 'opacity-100');
            icon.classList.remove('rotate-180');
            button.classList.remove('bg-editorial-surface-low', 'dark:bg-editorial-surface-low-dark');
        }
      });
    });
  });
</script>
