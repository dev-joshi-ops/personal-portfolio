---
import { resume } from '../data/resume';
---

<section id="experience" class="py-20 bg-slate-50 dark:bg-navy-900 relative transition-colors duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-white mb-4">Work Experience</h2>
        <div class="h-1 w-20 bg-primary rounded-full"></div>
    </div>

    <div class="space-y-12 relative">
      <!-- Vertical Line -->
      <div class="absolute left-0 md:left-1/2 top-0 bottom-0 w-px bg-slate-200 dark:bg-white/10 hidden md:block"></div>

      {resume.experience.map((job, index) => (
        <div class={`relative flex flex-col md:flex-row gap-8 ${index % 2 === 0 ? 'md:flex-row-reverse' : ''}`}>
          
          <!-- Timeline Dot -->
          <div class="absolute left-0 md:left-1/2 w-4 h-4 bg-primary rounded-full border-4 border-white dark:border-navy-900 transform -translate-x-[5px] md:-translate-x-1/2 mt-1.5 z-10 shadow-sm"></div>

          <!-- Content -->
          <div class="flex-1 ml-6 md:ml-0">
            <div class={`bg-white dark:bg-navy-800 p-8 rounded-2xl border border-slate-200 dark:border-white/5 hover:border-primary/30 transition-all duration-300 shadow-lg shadow-slate-200/50 dark:shadow-none group ${index % 2 === 0 ? 'md:text-left' : 'md:text-right'}`}>
              
              <div class={`flex flex-col gap-2 mb-4 ${index % 2 === 0 ? 'md:items-start' : 'md:items-end'}`}>
                <h3 class="text-xl font-bold text-slate-900 dark:text-white group-hover:text-primary transition-colors">
                  {job.position}
                </h3>
                <p class="text-primary font-medium">{job.company}</p>
                <span class="text-sm text-slate-500 dark:text-slate-400 font-mono bg-slate-100 dark:bg-navy-900 px-3 py-1 rounded-full border border-slate-200 dark:border-white/5 inline-block">
                    {job.startDate} — {job.endDate}
                </span>
              </div>
              
              <p class="text-slate-600 dark:text-slate-400 mb-6 leading-relaxed">{job.summary}</p>
              
              <ul class={`space-y-2 ${index % 2 === 0 ? '' : 'md:flex md:flex-col md:items-end'}`}>
                {job.highlights.map((highlight) => (
                  <li class="flex items-start text-slate-600 dark:text-slate-400 text-sm gap-2">
                    <span class="text-primary mt-1.5 h-1.5 w-1.5 rounded-full bg-primary flex-shrink-0"></span>
                    <span class="leading-relaxed">{highlight}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
          
          <!-- Empty Space for alternating layout -->
          <div class="flex-1 hidden md:block"></div>
        </div>
      ))}
    </div>
  </div>
</section>
