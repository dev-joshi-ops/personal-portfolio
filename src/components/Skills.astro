---
import { resume } from '../data/resume';
---

<section id="stack" class="py-20 bg-editorial-surface dark:bg-editorial-surface-dark border-t border-editorial-surface-highest dark:border-editorial-surface-highest-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-left mb-16">
      <h2 class="text-5xl md:text-7xl font-bold text-editorial-text dark:text-editorial-text-dark mb-12 font-serif italic tracking-tighter border-l-4 border-editorial-primary dark:border-editorial-primary-dark pl-8">Stack</h2>
    </div>

    <!-- Tabs Container -->
    <div class="skills-tabs relative">
      <!-- Tab Headers -->
      <div class="flex flex-wrap gap-x-8 gap-y-4 mb-12 relative pb-2">
        {[
          { id: 'cloud', label: 'Cloud' },
          { id: 'orchestration', label: 'Containers' },
          { id: 'iac', label: 'IaC' },
          { id: 'cicd', label: 'CI/CD' },
          { id: 'observability', label: 'Observability' },
          { id: 'governance', label: 'Security' }
        ].map((tab, index) => (
          <button
            class={`skill-tab-btn font-sans text-[16px] transition-all relative pb-2 group ${index === 0 ? 'active text-editorial-text dark:text-editorial-text-dark font-medium' : 'text-[#888] dark:text-editorial-secondary-dark hover:text-editorial-text'}`}
            data-tab={tab.id}
          >
            {tab.label}
            {/* Per-tab indicator for robust multi-line support */}
            <div class="absolute bottom-[-1px] left-0 h-[2px] bg-black dark:bg-white transition-all duration-300 ease-[cubic-bezier(0.4,0,0.2,1)] w-0 opacity-0 group-[.active]:w-full group-[.active]:opacity-100"></div>
          </button>
        ))}
      </div>

      <!-- Tab Content -->
      <div class="tab-contents min-h-[300px]">
        <!-- Cloud -->
        <div id="tab-cloud" class="skill-content grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4">
          {resume.skills.cloud.map((skill) => (
            <div class="skill-item py-5 px-6 border border-[#eee] dark:border-editorial-surface-highest-dark bg-white dark:bg-editorial-surface-low-dark group hover:border-editorial-primary transition-colors opacity-0 translate-y-2">
              <span class="block text-[17px] font-sans font-bold text-editorial-text dark:text-editorial-text-dark tracking-tight">{skill.name.split('(')[0].trim()}</span>
            </div>
          ))}
        </div>

        <!-- Orchestration -->
        <div id="tab-orchestration" class="skill-content hidden grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4">
          {resume.skills.containerization.map((skill) => (
            <div class="skill-item py-5 px-6 border border-[#eee] dark:border-editorial-surface-highest-dark bg-white dark:bg-editorial-surface-low-dark group hover:border-editorial-primary transition-colors opacity-0 translate-y-2">
              <span class="block text-[15px] font-sans font-medium text-editorial-text dark:text-editorial-text-dark">{skill}</span>
            </div>
          ))}
        </div>

        <!-- IaC -->
        <div id="tab-iac" class="skill-content hidden grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4">
          {resume.skills.iac.map((skill) => (
            <div class="skill-item py-5 px-6 border border-[#eee] dark:border-editorial-surface-highest-dark bg-white dark:bg-editorial-surface-low-dark group hover:border-editorial-primary transition-colors opacity-0 translate-y-2">
              <span class="block text-[17px] font-sans font-bold text-editorial-text dark:text-editorial-text-dark tracking-tight">{skill}</span>
            </div>
          ))}
        </div>

        <!-- CI/CD -->
        <div id="tab-cicd" class="skill-content hidden grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4">
          {resume.skills.cicd.map((skill) => (
            <div class="skill-item py-5 px-6 border border-[#eee] dark:border-editorial-surface-highest-dark bg-white dark:bg-editorial-surface-low-dark group hover:border-editorial-primary transition-colors opacity-0 translate-y-2">
              <span class="block text-[15px] font-sans font-medium text-editorial-text dark:text-editorial-text-dark">{skill}</span>
            </div>
          ))}
        </div>

        <!-- Observability -->
        <div id="tab-observability" class="skill-content hidden grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4">
          {resume.skills.observability.map((skill) => (
            <div class="skill-item py-5 px-6 border border-[#eee] dark:border-editorial-surface-highest-dark bg-white dark:bg-editorial-surface-low-dark group hover:border-editorial-primary transition-colors opacity-0 translate-y-2">
              <span class="block text-[15px] font-sans font-medium text-editorial-text dark:text-editorial-text-dark">{skill}</span>
            </div>
          ))}
        </div>

        <!-- Governance -->
        <div id="tab-governance" class="skill-content hidden grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4">
          {resume.skills.security?.map((skill) => (
            <div class="skill-item py-5 px-6 border border-[#eee] dark:border-editorial-surface-highest-dark bg-white dark:bg-editorial-surface-low-dark group hover:border-editorial-primary transition-colors opacity-0 translate-y-2">
              <span class="block text-[15px] font-sans font-medium text-editorial-text dark:text-editorial-text-dark">{skill}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .skill-item {
    transition: opacity 0.5s ease-out, transform 0.5s ease-out, border-color 0.2s ease-in-out;
  }
</style>

<script>
  function setupTabs() {
    const buttons = document.querySelectorAll('.skill-tab-btn');
    const contents = document.querySelectorAll('.skill-content');
    const indicator = document.getElementById('tab-indicator');

    function updateIndicator(tab) {
      // Logic handled via Tailwind group classes for mobile robustness
    }

    function animateItems(container) {
      const items = container.querySelectorAll('.skill-item');
      items.forEach((item, i) => {
        item.style.opacity = '0';
        item.style.transform = 'translateY(10px)';
        item.style.transitionDelay = '0s';
        
        // Trigger reflow
        void item.offsetWidth;

        setTimeout(() => {
          item.style.opacity = '1';
          item.style.transform = 'translateY(0)';
          item.style.transitionDelay = `${i * 0.04}s`;
        }, 50);
      });
    }

    // Initialize first tab
    const initialActive = document.querySelector('.skill-tab-btn.active');
    if (initialActive) {
      updateIndicator(initialActive);
      const initialContent = document.getElementById(`tab-${initialActive.getAttribute('data-tab')}`);
      if (initialContent) animateItems(initialContent);
    }

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const tabId = btn.getAttribute('data-tab');

        // Update buttons
        buttons.forEach(b => {
          b.classList.remove('active', 'text-editorial-text', 'dark:text-editorial-text-dark');
          b.classList.add('text-[#888]', 'dark:text-editorial-secondary-dark');
        });

        btn.classList.add('active', 'text-editorial-text', 'dark:text-editorial-text-dark');
        btn.classList.remove('text-[#888]', 'dark:text-editorial-secondary-dark');
        
        updateIndicator(btn);

        // Update content
        contents.forEach(content => {
          if (content.id === `tab-${tabId}`) {
            content.classList.remove('hidden');
            content.classList.add('grid');
            animateItems(content);
          } else {
            content.classList.add('hidden');
            content.classList.remove('grid');
          }
        });
      });
    });

    // Handle window resize to keep indicator aligned
    window.addEventListener('resize', () => {
      const activeBtn = document.querySelector('.skill-tab-btn.active');
      if (activeBtn) updateIndicator(activeBtn);
    });
  }

  // Run on initial load
  setupTabs();

  // Run on view transition if needed (Astro specifics)
  document.addEventListener('astro:after-swap', setupTabs);
</script>
