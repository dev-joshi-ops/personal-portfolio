---
const testimonials = [
  {
    quote: "Dev is not only a highly skilled professional but also a smart, opportunistic, and tinkering-minded individual who brings a unique blend of creativity and technical expertise to every project.",
    author: "Harmanjot Singh Bhatia",
    role: "Solution Architect (Cloud, Data & AI/ML) | AI Tech Lead",
    image: "https://ui-avatars.com/api/?name=Harmanjot+Singh+Bhatia&background=0EA5E9&color=fff"
  },
  {
    quote: "Dev's extraordinary technical expertise, unmatched productivity, and unwavering dedication have profoundly impacted our operations and overall efficiency.",
    author: "Gavin Wang",
    role: "CTO | Head of Engineering",
    image: "https://ui-avatars.com/api/?name=Gavin+Wang&background=10B981&color=fff"
  }
];

// Duplicate for seamless looping
const allTestimonials = [...testimonials, ...testimonials];
---

<section id="testimonials" class="py-20 bg-editorial-surface dark:bg-editorial-surface-dark border-t border-editorial-surface-highest dark:border-editorial-surface-highest-dark overflow-hidden">
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-left mb-16 max-w-2xl">
      <h2 class="sr-only">Client Testimonials & Endorsements</h2>
      <h2 aria-hidden="true" class="text-4xl md:text-6xl font-bold text-editorial-text dark:text-editorial-text-dark mb-6 tracking-tight   border-l-4 border-editorial-primary dark:border-editorial-primary-dark pl-8">
        Endorsements
      </h2>
      <p class="text-editorial-secondary dark:text-editorial-secondary-dark text-xl  font-light leading-relaxed">
        Recorded testimonials from technical leadership regarding architectural impact and operational efficiency.
      </p>
    </div>

    <!-- Static Grid (Editorial style often favors static content over carousels) -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-0 border-t border-l border-editorial-surface-highest dark:border-editorial-surface-highest-dark">
        {testimonials.map((testimonial) => (
            <div class="p-6 sm:p-10 md:p-12 border-r border-b border-editorial-surface-highest dark:border-editorial-surface-highest-dark bg-editorial-surface dark:bg-editorial-surface-dark hover:bg-editorial-surface-low dark:hover:bg-editorial-surface-low-dark transition-colors group flex flex-col justify-between">
                <!-- Content -->
                <div class="relative mb-12">
                    <span class=" text-6xl md:text-8xl text-editorial-primary dark:text-editorial-primary-dark opacity-10 absolute -top-4 -left-2 md:-top-8 md:-left-4 select-none">“</span>
                    <p class="text-editorial-text dark:text-editorial-text-dark text-xl sm:text-2xl   leading-relaxed relative z-10">
                        {testimonial.quote}
                    </p>
                </div>

                <div class="flex items-center gap-4 sm:gap-6 mt-auto">
                    <div class="w-12 h-12 sm:w-16 sm:h-16 bg-editorial-surface-highest dark:bg-editorial-surface-highest-dark overflow-hidden grayscale group-hover:grayscale-0 transition-all duration-700 border border-editorial-surface-highest dark:border-editorial-surface-highest-dark flex-shrink-0">
                        <img 
                            src={testimonial.image} 
                            alt={testimonial.author}
                            class="w-full h-full object-cover"
                            loading="lazy"
                            width="64"
                            height="64"
                        />
                    </div>
                    
                    <div class="space-y-1">
                        <h3 class=" font-bold text-lg sm:text-xl text-editorial-text dark:text-editorial-text-dark leading-tight">
                            {testimonial.author}
                        </h3>
                        <p class="text-[9px] sm:text-[10px] font-mono uppercase tracking-[0.1em] sm:tracking-[0.2em] text-editorial-secondary dark:text-editorial-secondary-dark">
                            {testimonial.role}
                        </p>
                    </div>
                </div>
            </div>
        ))}
    </div>
  </div>
</section>
