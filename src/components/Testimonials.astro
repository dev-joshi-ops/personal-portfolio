---
const testimonials = [
  {
    quote: "Dev is not only a highly skilled professional but also a smart, opportunistic, and tinkering-minded individual who brings a unique blend of creativity and technical expertise to every project.",
    author: "Harmanjot Singh Bhatia",
    role: "Solution Architect (Cloud, Data & AI/ML) | AI Tech Lead",
    image: "https://ui-avatars.com/api/?name=Harmanjot+Singh+Bhatia&background=0EA5E9&color=fff"
  },
  {
    quote: "Dev's extraordinary technical expertise, unmatched productivity, and unwavering dedication have profoundly impacted our operations and overall efficiency.",
    author: "Gavin Wang",
    role: "CTO | Head of Engineering",
    image: "https://ui-avatars.com/api/?name=Gavin+Wang&background=10B981&color=fff"
  }
];

// Duplicate for seamless looping
const allTestimonials = [...testimonials, ...testimonials];
---

<section id="testimonials" class="py-20 bg-white dark:bg-navy-900 transition-colors duration-300 overflow-hidden relative">
    <!-- Background Elements -->
    <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none">
        <div class="absolute top-[-10%] right-[-5%] w-96 h-96 bg-blue-500/5 rounded-full blur-3xl"></div>
        <div class="absolute bottom-[-10%] left-[-5%] w-96 h-96 bg-purple-500/5 rounded-full blur-3xl"></div>
    </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-bold text-slate-900 dark:text-white mb-4 tracking-tight">
        Trusted by Engineering Teams
      </h2>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
        Collaborating with industry leaders to deliver robust infrastructure solutions.
      </p>
    </div>

    <!-- Carousel Wrapper -->
    <div class="relative group carousel-wrapper">
        <div class="carousel-container overflow-hidden">
            <div class="carousel-track flex transition-transform duration-500 ease-out cursor-grab active:cursor-grabbing">
                {allTestimonials.map((testimonial) => (
                    <div class="carousel-slide w-full md:w-1/2 flex-shrink-0 p-4 select-none">
                        <div class="bg-white dark:bg-navy-800 rounded-2xl p-8 shadow-lg shadow-slate-200/50 dark:shadow-none border border-slate-200 dark:border-white/5 relative group/card hover:-translate-y-1 transition-all duration-300 h-full flex flex-col justify-between">
                        
                            <!-- Large Quote Icon -->
                            <div class="absolute top-6 right-8 text-blue-100 dark:text-blue-500/10 font-serif text-8xl leading-none select-none pointer-events-none group-hover/card:scale-110 transition-transform duration-300">
                                &rdquo;
                            </div>

                            <!-- Content -->
                            <div class="relative z-10">
                                <p class="text-slate-700 dark:text-slate-300 text-lg italic mb-8 leading-relaxed">
                                "{testimonial.quote}"
                                </p>
                            </div>

                            <div class="relative z-10 flex items-center gap-4 mt-auto">
                                <div class="relative">
                                    <div class="w-12 h-12 rounded-full overflow-hidden border-2 border-white dark:border-navy-700 shadow-md">
                                        <img 
                                            src={testimonial.image} 
                                            alt={testimonial.author}
                                            class="w-full h-full object-cover"
                                            loading="lazy"
                                            draggable="false"
                                        />
                                    </div>
                                    <!-- Online Indicator -->
                                    <div class="absolute bottom-0 right-0 w-3 h-3 bg-green-500 border-2 border-white dark:border-navy-800 rounded-full"></div>
                                </div>
                                
                                <div>
                                    <h4 class="font-bold text-green-600 dark:text-green-400 text-base">
                                        {testimonial.author}
                                    </h4>
                                    <p class="text-sm text-slate-500 dark:text-slate-400">
                                        {testimonial.role}
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>

        <!-- Navigation Arrows -->
        <button class="prev-btn absolute top-1/2 -left-4 md:-left-12 transform -translate-y-1/2 bg-white dark:bg-navy-800 p-3 rounded-full shadow-lg text-slate-600 dark:text-white hover:text-green-500 dark:hover:text-green-400 transition-colors z-20 focus:outline-none opacity-0 group-hover:opacity-100 transition-opacity duration-300 hidden md:block" aria-label="Previous slide">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <button class="next-btn absolute top-1/2 -right-4 md:-right-12 transform -translate-y-1/2 bg-white dark:bg-navy-800 p-3 rounded-full shadow-lg text-slate-600 dark:text-white hover:text-green-500 dark:hover:text-green-400 transition-colors z-20 focus:outline-none opacity-0 group-hover:opacity-100 transition-opacity duration-300 hidden md:block" aria-label="Next slide">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </button>
    </div>

    <!-- Dots -->
    <div class="flex justify-center gap-2 mt-8">
        {testimonials.map((_, index) => (
            <button class="dot-btn w-2.5 h-2.5 rounded-full bg-slate-300 dark:bg-navy-700 hover:bg-green-500 dark:hover:bg-green-400 transition-colors" data-index={index} aria-label={`Go to slide ${index + 1}`}></button>
        ))}
    </div>
  </div>
</section>

<script>
    function initCarousel() {
        const track = document.querySelector('.carousel-track');
        const slides = document.querySelectorAll('.carousel-slide');
        const nextBtn = document.querySelector('.next-btn');
        const prevBtn = document.querySelector('.prev-btn');
        const dots = document.querySelectorAll('.dot-btn');
        
        if (!track || slides.length === 0) return;

        let currentIndex = 0;
        const totalOriginalSlides = 2; 
        const totalSlides = slides.length;
        let autoPlayInterval;

        const getSlidesPerView = () => window.innerWidth >= 768 ? 2 : 1;

        function updateCarousel(index) {
            const slidesPerView = getSlidesPerView();
            const slideWidth = 100 / slidesPerView;
            
            // Boundary checks
            if (index < 0) index = totalOriginalSlides - 1;
            // If we go past the end, loop back to 0
            if (index > totalSlides - slidesPerView) index = 0;

            track.style.transform = `translateX(-${index * slideWidth}%)`;
            
            // Update dots
            dots.forEach((dot, i) => {
                const activeIndex = index % totalOriginalSlides;
                
                if (i === activeIndex) {
                    dot.classList.add('bg-green-500', 'dark:bg-green-400');
                    dot.classList.remove('bg-slate-300', 'dark:bg-navy-700');
                } else {
                    dot.classList.remove('bg-green-500', 'dark:bg-green-400');
                    dot.classList.add('bg-slate-300', 'dark:bg-navy-700');
                }
            });

            currentIndex = index;
        }

        function nextSlide() {
            updateCarousel(currentIndex + 1);
        }

        function prevSlide() {
            updateCarousel(currentIndex - 1);
        }

        // Event Listeners
        nextBtn?.addEventListener('click', () => {
            nextSlide();
            resetAutoPlay();
        });

        prevBtn?.addEventListener('click', () => {
            prevSlide();
            resetAutoPlay();
        });

        dots.forEach((dot, index) => {
            dot.addEventListener('click', () => {
                updateCarousel(index);
                resetAutoPlay();
            });
        });

        // Touch Support (Simple Swipe)
        let touchStartX = 0;
        let touchEndX = 0;

        track.addEventListener('touchstart', (e) => {
            touchStartX = e.changedTouches[0].screenX;
            stopAutoPlay();
        }, { passive: true });

        track.addEventListener('touchend', (e) => {
            touchEndX = e.changedTouches[0].screenX;
            handleSwipe();
            startAutoPlay();
        }, { passive: true });

        function handleSwipe() {
            if (touchEndX < touchStartX - 50) nextSlide();
            if (touchEndX > touchStartX + 50) prevSlide();
        }

        // Auto Play
        function startAutoPlay() {
            stopAutoPlay();
            autoPlayInterval = setInterval(nextSlide, 5000);
        }

        function stopAutoPlay() {
            if (autoPlayInterval) clearInterval(autoPlayInterval);
        }

        function resetAutoPlay() {
            stopAutoPlay();
            startAutoPlay();
        }

        // Initialize
        updateCarousel(0);
        startAutoPlay();

        // Handle Resize
        window.addEventListener('resize', () => {
            updateCarousel(currentIndex);
        });
    }

    // Run on load
    initCarousel();
    document.addEventListener('astro:page-load', initCarousel);
</script>
