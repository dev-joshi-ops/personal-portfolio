---
import { resume } from '../data/resume';
---

<section id="cli" class="py-20 bg-slate-50 dark:bg-navy-900 transition-colors duration-300">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-white mb-4">Interactive Terminal</h2>
        <p class="text-slate-600 dark:text-slate-400">Get to know me via CLI. Type <code class="bg-white dark:bg-navy-800 px-2 py-1 rounded text-primary font-mono text-sm border border-slate-200 dark:border-white/10">help</code> to start.</p>
    </div>

    <div class="bg-[#1e1e1e] rounded-lg shadow-2xl overflow-hidden border border-slate-200 dark:border-white/10 font-mono text-sm md:text-base transform transition-transform hover:scale-[1.01] duration-300">
      <!-- Terminal Header -->
      <div class="bg-[#2d2d2d] px-4 py-2 flex items-center gap-2 border-b border-[#3d3d3d]">
        <div class="flex gap-2">
            <div class="w-3 h-3 rounded-full bg-[#ff5f56]"></div>
            <div class="w-3 h-3 rounded-full bg-[#ffbd2e]"></div>
            <div class="w-3 h-3 rounded-full bg-[#27c93f]"></div>
        </div>
        <div class="ml-4 text-slate-400 text-xs flex-1 text-center font-sans">user@dev-portfolio: ~</div>
      </div>

      <!-- Terminal Body -->
      <div class="p-4 h-[400px] overflow-y-auto scrollbar-thin scrollbar-thumb-slate-700 scrollbar-track-transparent" id="terminal-container" onclick="document.getElementById('terminal-input').focus()">
        <div id="terminal-output" class="mb-2">
          <div class="mb-4 text-slate-300">
            <span class="text-green-400">➜</span> <span class="text-blue-400">~</span> <span class="text-slate-400"># Welcome to Dev's Portfolio CLI v1.0.0</span><br/>
            <span class="text-slate-400"># Type 'help' to see available commands.</span>
          </div>
        </div>
        
        <!-- Input Line -->
        <div class="flex items-center gap-2 text-slate-300">
            <span class="text-green-400">➜</span>
            <span class="text-blue-400">~</span>
            <input type="text" id="terminal-input" class="bg-transparent border-none outline-none flex-1 text-slate-100 focus:ring-0 p-0 font-mono caret-transparent" autocomplete="off" spellcheck="false" />
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ resume }}>
    const input = document.getElementById('terminal-input');
    const output = document.getElementById('terminal-output');
    const container = document.getElementById('terminal-container');

    const commands = {
        help: {
            desc: 'List available commands',
            action: () => {
                return `
<div class="grid grid-cols-[100px_1fr] gap-2 text-slate-300">
    <span class="text-yellow-400">about</span>    <span>Who am I?</span>
    <span class="text-yellow-400">skills</span>   <span>My technical stack</span>
    <span class="text-yellow-400">projects</span> <span>View recent work</span>
    <span class="text-yellow-400">contact</span>  <span>Get in touch</span>
    <span class="text-yellow-400">clear</span>    <span>Clear screen</span>
</div>`;
            }
        },
        about: {
            desc: 'Who am I?',
            action: () => {
                return `<div class="text-slate-300 max-w-2xl leading-relaxed">${resume.basics.summary}</div>`;
            }
        },
        skills: {
            desc: 'My technical stack',
            action: () => {
                const allSkills = [
                    ...resume.skills.cloud.map(s => s.name),
                    ...resume.skills.containerization,
                    ...resume.skills.iac,
                    ...resume.skills.cicd,
                    ...(resume.skills.databases || []),
                    ...(resume.skills.platforms || [])
                ];
                return `<div class="text-slate-300 flex flex-wrap gap-2">
                    ${allSkills.map(s => `<span class="px-2 py-0.5 bg-slate-800 rounded text-green-400">${s}</span>`).join('')}
                </div>`;
            }
        },
        projects: {
            desc: 'View recent work',
            action: () => {
                const projectList = resume.projects.map(p => 
                    `<div class="mb-2">
                        <span class="text-blue-400 font-bold">${p.name}</span>: ${p.description}
                     </div>`
                ).join('');
                return `<div class="text-slate-300">
                    ${projectList}
                    <div class="mt-2 text-slate-500 italic">Scroll up to the Projects section for more details!</div>
                </div>`;
            }
        },
        contact: {
            desc: 'Get in touch',
            action: () => {
                const linkedIn = resume.basics.profiles.find(p => p.network === 'LinkedIn');
                return `<div class="text-slate-300">
                    <div><span class="text-yellow-400 w-20 inline-block">Email:</span> <a href="mailto:${resume.basics.email}" class="text-blue-400 hover:underline">${resume.basics.email}</a></div>
                    ${linkedIn ? `<div><span class="text-yellow-400 w-20 inline-block">LinkedIn:</span> <a href="${linkedIn.url}" target="_blank" class="text-blue-400 hover:underline">${linkedIn.username}</a></div>` : ''}
                </div>`;
            }
        },
        clear: {
            desc: 'Clear screen',
            action: () => {
                output.innerHTML = '';
                return '';
            }
        }
    };

    input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
            const cmd = input.value.trim().toLowerCase();
            
            // Add command to output
            if (cmd !== 'clear') {
                output.innerHTML += `
                    <div class="mb-2">
                        <span class="text-green-400">➜</span> <span class="text-blue-400">~</span> <span class="text-slate-100">${input.value}</span>
                    </div>
                `;
            }

            // Process command
            if (cmd) {
                if (commands[cmd]) {
                    const result = commands[cmd].action();
                    if (result) {
                        output.innerHTML += `<div class="mb-4">${result}</div>`;
                    }
                } else {
                    output.innerHTML += `<div class="mb-4 text-red-400">Command not found: ${cmd}. Type 'help' for available commands.</div>`;
                }
            }

            input.value = '';
            
            // Scroll to bottom
            setTimeout(() => {
                container.scrollTop = container.scrollHeight;
            }, 10);
        }
    });
</script>
