---
import { resume } from '../data/resume';
---

<section id="cli" class="py-20 bg-editorial-surface dark:bg-editorial-surface-dark border-t border-editorial-surface-highest dark:border-editorial-surface-highest-dark">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-left mb-16">
        <h2 class="text-4xl md:text-6xl font-bold text-editorial-text dark:text-editorial-text-dark tracking-tight font-serif italic italic border-l-4 border-editorial-primary dark:border-editorial-primary-dark pl-8">Interactive Terminal</h2>
        <p class="text-editorial-secondary dark:text-editorial-secondary-dark text-lg font-sans font-light mt-6">Get to know me via CLI. Type <code class="bg-editorial-surface-highest dark:bg-editorial-surface-highest-dark px-2 py-0.5 text-editorial-primary dark:text-editorial-primary-dark font-mono text-sm">help</code> to start.</p>
    </div>

    <div class="bg-[#111111] shadow-none overflow-hidden border border-editorial-surface-highest dark:border-editorial-surface-highest-dark font-mono text-sm md:text-base">
      <!-- Terminal Header -->
      <div class="bg-[#1a1a1a] px-6 py-3 flex items-center gap-4 border-b border-[#2d2d2d] dark:border-editorial-surface-highest-dark">
        <div class="flex gap-2">
            <div class="w-2.5 h-2.5 bg-[#ff5f56]"></div>
            <div class="w-2.5 h-2.5 bg-[#ffbd2e]"></div>
            <div class="w-2.5 h-2.5 bg-[#27c93f]"></div>
        </div>
        <div class="text-[#888] text-[10px] uppercase tracking-[0.2em] flex-1 text-center font-mono">operational-shell v3.0</div>
      </div>

      <!-- Terminal Body -->
      <div class="p-8 h-[450px] overflow-y-auto scrollbar-thin scrollbar-thumb-[#444] scrollbar-track-transparent" id="terminal-container" onclick="document.getElementById('terminal-input').focus()">
        <div id="terminal-output" class="mb-2">
          <div class="mb-6 text-slate-400">
            <span class="text-editorial-primary dark:text-editorial-primary-dark">➜</span> <span class="text-editorial-primary dark:text-editorial-primary-dark font-bold">~</span> <span class="opacity-60"># Technical Monograph CLI Protocol Loaded</span><br/>
            <span class="opacity-60"># Initialization complete. Type 'help' to begin inquiry.</span>
          </div>
        </div>
        
        <!-- Input Line -->
        <div class="flex items-center gap-3 text-slate-300">
            <span class="text-editorial-primary dark:text-editorial-primary-dark">➜</span>
            <span class="text-editorial-primary dark:text-editorial-primary-dark font-bold">~</span>
            <input type="text" id="terminal-input" class="bg-transparent border-none outline-none flex-1 text-slate-100 focus:ring-0 p-0 font-mono caret-editorial-primary dark:caret-editorial-primary-dark" autocomplete="off" spellcheck="false" />
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ resume }}>
    const input = document.getElementById('terminal-input');
    const output = document.getElementById('terminal-output');
    const container = document.getElementById('terminal-container');

    const commands = {
        help: {
            desc: 'List available commands',
            action: () => {
                return `
<div class="grid grid-cols-[100px_1fr] gap-2 text-slate-300">
    <span class="text-editorial-primary font-bold">about</span>    <span>Identity Summary</span>
    <span class="text-editorial-primary font-bold">skills</span>   <span>Technical Inventory</span>
    <span class="text-editorial-primary font-bold">projects</span> <span>Operational Archives</span>
    <span class="text-editorial-primary font-bold">contact</span>  <span>Direct Inquiries</span>
    <span class="text-editorial-primary font-bold">clear</span>    <span>Reset Interface</span>
</div>`;
            }
        },
        about: {
            desc: 'Who am I?',
            action: () => {
                return `<div class="text-slate-300 max-w-2xl leading-relaxed italic border-l border-editorial-primary pl-4">${resume.basics.summary}</div>`;
            }
        },
        skills: {
            desc: 'My technical stack',
            action: () => {
                const allSkills = [
                    ...resume.skills.cloud.map(s => s.name),
                    ...resume.skills.containerization,
                    ...resume.skills.iac,
                    ...resume.skills.cicd,
                    ...(resume.skills.databases || []),
                    ...(resume.skills.platforms || []),
                    ...(resume.skills.emerging || []),
                    ...(resume.skills.security || [])
                ];
                return `<div class="text-slate-300 flex flex-wrap gap-2">
                    ${allSkills.map(s => `<span class="px-2 py-0.5 bg-[#2d2d2d] border border-[#3d3d3d] text-editorial-primary text-xs uppercase tracking-widest">${s}</span>`).join('')}
                </div>`;
            }
        },
        projects: {
            desc: 'View recent work',
            action: () => {
                const projectList = resume.projects.map(p => 
                    `<div class="mb-4">
                        <span class="text-editorial-primary font-bold uppercase tracking-widest text-xs">${p.name}</span>
                        <p class="text-slate-400 text-sm mt-1 italic">${p.description}</p>
                     </div>`
                ).join('');
                return `<div class="text-slate-300">
                    ${projectList}
                    <div class="mt-2 text-slate-500 italic text-[10px] uppercase tracking-widest">Reference Archives Section for Full Details</div>
                </div>`;
            }
        },
        contact: {
            desc: 'Get in touch',
            action: () => {
                const linkedIn = resume.basics.profiles.find(p => p.network === 'LinkedIn');
                return `<div class="text-slate-300 space-y-2">
                    <div><span class="text-editorial-primary w-24 inline-block font-bold text-xs uppercase tracking-widest">Email:</span> <a href="mailto:${resume.basics.email}" class="hover:text-editorial-primary underline decoration-editorial-primary/30">${resume.basics.email}</a></div>
                    ${linkedIn ? `<div><span class="text-editorial-primary w-24 inline-block font-bold text-xs uppercase tracking-widest">LinkedIn:</span> <a href="${linkedIn.url}" target="_blank" class="hover:text-editorial-primary underline decoration-editorial-primary/30">${linkedIn.username}</a></div>` : ''}
                </div>`;
            }
        },
        clear: {
            desc: 'Clear screen',
            action: () => {
                output.innerHTML = '';
                return '';
            }
        }
    };

    input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
            const cmd = input.value.trim().toLowerCase();
            
            // Add command to output
            if (cmd !== 'clear') {
                output.innerHTML += `
                    <div class="mb-4">
                        <span class="text-editorial-primary">➜</span> <span class="text-editorial-primary font-bold">~</span> <span class="text-slate-100 italic">${input.value}</span>
                    </div>
                `;
            }

            // Process command
            if (cmd) {
                if (commands[cmd]) {
                    const result = commands[cmd].action();
                    if (result) {
                        output.innerHTML += `<div class="mb-4">${result}</div>`;
                    }
                } else {
                    output.innerHTML += `<div class="mb-4 text-red-400">Command not found: ${cmd}. Type 'help' for available commands.</div>`;
                }
            }

            input.value = '';
            
            // Scroll to bottom
            setTimeout(() => {
                container.scrollTop = container.scrollHeight;
            }, 10);
        }
    });
</script>
