---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { resume } from '../../data/resume';

const categories = ["All", "Tools", "Templates", "Infrastructure"];
const projects = resume.openSource;
---

<Layout
  title={`Open Source | ${resume.basics.name}`}
  description="Tools, scripts, and templates built and shared with the DevOps community by Dev Joshi."
>
  <Navbar />

  <main class="pt-32 pb-32 min-h-screen bg-editorial-surface dark:bg-editorial-surface-dark transition-colors duration-500">
    <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Header Section -->
      <header class="max-w-4xl mb-16 border-l-4 border-editorial-primary dark:border-editorial-primary-dark pl-8">
        <h1 class=" text-5xl md:text-7xl font-bold tracking-tighter text-editorial-text dark:text-editorial-text-dark mb-6 leading-tight ">
          Open Source
        </h1>
        <p class=" text-xl md:text-2xl text-editorial-secondary dark:text-editorial-secondary-dark max-w-3xl leading-relaxed">
          Tools, scripts, and templates I've built and shared with the DevOps community.
        </p>
      </header>

      <!-- Stats Row (Tectonic Divider) -->
      <section class="border-t border-b border-editorial-outline/30 dark:border-editorial-secondary-dark/30 py-8 mb-20">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="md:border-r border-editorial-outline/30 dark:border-editorial-secondary-dark/30 pr-8">
            <span class="block  text-4xl text-editorial-text dark:text-editorial-text-dark mb-2">{resume.openSource.length}</span>
            <span class="block font-mono text-[10px] uppercase tracking-widest text-editorial-secondary dark:text-editorial-secondary-dark font-bold">Public Repositories</span>
          </div>
          <div class="md:border-r border-editorial-outline/30 dark:border-editorial-secondary-dark/30 px-0 md:px-8">
            <span class="block  text-2xl md:text-3xl lg:text-4xl text-editorial-text dark:text-editorial-text-dark mb-2">Python, Docker, TS</span>
            <span class="block font-mono text-[10px] uppercase tracking-widest text-editorial-secondary dark:text-editorial-secondary-dark font-bold">Primary Languages</span>
          </div>
          <div class="pl-0 md:pl-8">
            <span class="block  text-4xl text-editorial-text dark:text-editorial-text-dark mb-2">100%</span>
            <span class="block font-mono text-[10px] uppercase tracking-widest text-editorial-secondary dark:text-editorial-secondary-dark font-bold">Free & Open</span>
          </div>
        </div>
      </section>

      <!-- Filter Tabs -->
      <nav class="flex flex-wrap gap-8 mb-12 pb-2">
        {categories.map((cat, index) => (
          <button 
            data-filter={cat.toLowerCase()}
            class={`filter-btn font-mono text-xs pb-2 tracking-widest uppercase transition-all duration-300 relative group ${index === 0 ? 'active text-editorial-primary dark:text-editorial-primary-dark font-bold' : 'text-editorial-secondary dark:text-editorial-secondary-dark hover:text-editorial-text dark:hover:text-editorial-text-dark'}`}
          >
            {cat}
            <div class="absolute bottom-0 left-0 h-[2px] bg-editorial-primary dark:bg-editorial-primary-dark transition-all duration-300 w-0 group-[.active]:w-full opacity-0 group-[.active]:opacity-100"></div>
          </button>
        ))}
      </nav>

      <!-- Project Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-24" id="os-grid">
        {projects.map((project) => (
          <article 
            class="os-card bg-editorial-surface-low dark:bg-editorial-surface-low-dark p-8 lg:p-12 transition-all duration-500 hover:bg-editorial-surface-highest dark:hover:bg-editorial-surface-highest-dark flex flex-col h-full group border border-transparent hover:border-editorial-surface-highest dark:hover:border-editorial-surface-highest-dark"
            data-category={project.category.toLowerCase()}
          >
            <div class="flex justify-between items-start mb-6">
              <h2 class=" text-3xl tracking-tight text-editorial-text dark:text-editorial-text-dark group-hover:text-editorial-primary dark:group-hover:text-editorial-primary-dark transition-colors">{project.name}</h2>
              <span class="bg-editorial-surface dark:bg-editorial-surface-dark text-editorial-secondary dark:text-editorial-secondary-dark font-mono text-[10px] px-3 py-1 border border-editorial-outline/20 dark:border-editorial-secondary-dark/20 uppercase tracking-widest font-bold">{project.category.slice(0, -1)}</span>
            </div>
            <p class=" text-sm md:text-base text-editorial-secondary dark:text-editorial-secondary-dark leading-relaxed mb-12 flex-grow">
              {project.description}
            </p>
            <div class="mt-auto">
              <div class="flex flex-wrap gap-3 mb-8">
                {project.tags.map((tag, tIndex) => (
                  <span class={`font-mono text-[10px] tracking-widest text-editorial-secondary dark:text-editorial-secondary-dark uppercase font-bold ${tIndex > 0 ? 'border-l border-editorial-outline/30 dark:border-editorial-secondary-dark/30 pl-3' : ''}`}>
                    {tag}
                  </span>
                ))}
              </div>
              <div class="flex items-center gap-6">
                <a class="font-mono text-[10px] tracking-widest uppercase text-editorial-text dark:text-editorial-text-dark hover:text-editorial-primary dark:hover:text-editorial-primary-dark transition-colors flex items-center gap-1 font-bold" href={project.github} target="_blank" rel="noopener noreferrer">
                  Source <span class="text-sm">↗</span>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
    
    <!-- Bottom Banner -->
    <section class="bg-editorial-surface-low dark:bg-editorial-surface-highest-dark py-24 px-8 border-t border-editorial-outline/20 dark:border-editorial-secondary-dark/20">
      <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-start md:items-center justify-between gap-12">
        <h2 class=" text-4xl md:text-5xl text-editorial-text dark:text-editorial-text-dark tracking-tight max-w-2xl leading-tight">
          Have an idea for a tool? Let's build it together.
        </h2>
        <a class="inline-flex items-center justify-center px-8 py-4 bg-editorial-text dark:bg-editorial-primary-dark text-editorial-surface dark:text-editorial-surface-dark font-mono text-[10px] uppercase tracking-[0.2em] font-bold hover:bg-editorial-primary dark:hover:bg-editorial-text-dark transition-colors duration-300 shrink-0 shadow-lg shadow-editorial-primary/10" href="https://calendly.com/joshid647/30min" target="_blank" rel="noopener noreferrer">
          Book a Call <span class="ml-2 text-sm">↗</span>
        </a>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<style>
  .os-card {
    transition: opacity 0.3s ease, transform 0.3s ease, background-color 0.3s ease, border-color 0.3s ease;
    transform: scale(1);
    opacity: 1;
  }
  
  .os-card.hidden-card {
    opacity: 0;
    transform: scale(0.98);
    pointer-events: none;
  }
</style>

<script>
  function setupOSFilters() {
    const filters = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.os-card');

    filters.forEach(btn => {
      btn.addEventListener('click', () => {
        const filterValue = btn.getAttribute('data-filter');

        // Update active state
        filters.forEach(f => {
          f.classList.remove('active', 'text-editorial-primary', 'dark:text-editorial-primary-dark', 'font-bold');
          f.classList.add('text-editorial-secondary', 'dark:text-editorial-secondary-dark');
        });
        btn.classList.add('active', 'text-editorial-primary', 'dark:text-editorial-primary-dark', 'font-bold');
        btn.classList.remove('text-editorial-secondary', 'dark:text-editorial-secondary-dark');

        // Filter cards with animation
        cards.forEach(card => {
          const category = (card as HTMLElement).dataset.category;
          const isMatch = filterValue === 'all' || category === filterValue;
          
          if (isMatch) {
            (card as HTMLElement).style.display = 'flex';
            // Trigger reflow for animation
            void (card as HTMLElement).offsetWidth;
            (card as HTMLElement).classList.remove('hidden-card');
          } else {
            (card as HTMLElement).classList.add('hidden-card');
            // Wait for transition before hiding to prevent layout jump
            setTimeout(() => {
              if ((card as HTMLElement).classList.contains('hidden-card')) {
                (card as HTMLElement).style.display = 'none';
              }
            }, 300);
          }
        });
      });
    });
  }

  setupOSFilters();
  document.addEventListener('astro:after-swap', setupOSFilters);
</script>

