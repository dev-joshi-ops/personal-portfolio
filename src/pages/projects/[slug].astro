---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import { resume } from '../../data/resume';
import { Image } from 'astro:assets';

// Import project images for optimization
import liferayLogo from '../../assets/images/liferay-logo.png';
import cloudArch from '../../assets/images/cloud-architecture.jpg';
import eventStream from '../../assets/images/event-streaming.jpg';

const imageMap = {
  "/images/liferay-logo.png": liferayLogo,
  "/images/cloud-architecture.jpg": cloudArch,
  "/images/event-streaming.jpg": eventStream,
};

export function getStaticPaths() {
  return resume.projects.map((project) => ({
    params: { 
      slug: project.name.toLowerCase().replace(/ /g, '-').replace(/[^\w-]+/g, '') 
    },
    props: { project },
  }));
}

const { project } = Astro.props;

const siteUrl = "https://dev-joshi.pages.dev";
const slug = project.name.toLowerCase().replace(/ /g, '-').replace(/[^\w-]+/g, '');
const projectUrl = `${siteUrl}/projects/${slug}`;

// Trim description to max 155 chars at a natural boundary
const metaDescription = project.description.length > 155
  ? project.description.substring(0, project.description.lastIndexOf(' ', 152)) + '.'
  : project.description;

// BreadcrumbList Schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Projects", "item": `${siteUrl}/#projects` },
    { "@type": "ListItem", "position": 3, "name": project.name, "item": projectUrl }
  ]
};
---

<Layout
  title={`${project.name} — DevOps Case Study | Dev Joshi`}
  description={metaDescription}
  keywords={project.tags.join(", ")}
  jsonLd={breadcrumbSchema}
>
  <Navbar />
  <main class="pt-32 pb-32 bg-editorial-surface dark:bg-editorial-surface-dark min-h-screen transition-colors duration-500">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Header -->
      <div class="mb-16">
        <a href="/#projects" class="inline-flex items-center text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-editorial-secondary dark:text-editorial-secondary-dark hover:text-editorial-primary dark:hover:text-editorial-primary-dark transition-colors mb-12 group">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-3 group-hover:-translate-x-1 transition-transform"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
            Return to Archives
        </a>
        <h1 class="text-4xl md:text-7xl font-bold text-editorial-text dark:text-editorial-text-dark mb-8 tracking-tight   border-l-4 border-editorial-primary dark:border-editorial-primary-dark pl-8">
            {project.name}
        </h1>
        <div class="flex flex-wrap gap-3">
            <span class="px-4 py-1.5 bg-editorial-primary dark:bg-editorial-primary-dark text-editorial-surface dark:text-editorial-surface-dark text-[10px] font-mono font-bold uppercase tracking-[0.2em]">
                {project.category}
            </span>
            {project.tags.map((tag) => (
                <span class="px-4 py-1.5 bg-editorial-surface-highest dark:bg-editorial-surface-highest-dark text-editorial-text dark:text-editorial-text-dark text-[10px] font-mono font-bold uppercase tracking-[0.2em]">
                    {tag}
                </span>
            ))}
        </div>
      </div>

      <!-- Hero Image -->
      <div class="overflow-hidden mb-24 border border-editorial-surface-highest dark:border-editorial-surface-highest-dark bg-editorial-surface-low dark:bg-editorial-surface-low-dark">
        {imageMap[project.image] ? (
          <Image 
            src={imageMap[project.image]} 
            alt={`${project.name} specification visual`} 
            class="w-full h-64 md:h-[600px] object-cover grayscale hover:grayscale-0 transition-all duration-1000 ease-in-out"
            width={1200}
            height={600}
            loading="eager"
          />
        ) : (
          <img 
            src={project.image} 
            alt={`${project.name} specification visual`} 
            loading="lazy" 
            class="w-full h-64 md:h-[600px] object-cover grayscale hover:grayscale-0 transition-all duration-1000 ease-in-out" 
          />
        )}
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-24">
        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-24">
            
            <!-- Challenge -->
            <section class="border-t border-editorial-surface-highest dark:border-editorial-surface-highest-dark pt-12">
                <h2 class="text-xs font-mono font-bold text-editorial-primary dark:text-editorial-primary-dark uppercase tracking-[0.3em] mb-8">Objective & Constraints</h2>
                <p class="text-editorial-text dark:text-editorial-text-dark leading-relaxed text-2xl  ">
                    {project.details?.challenge || project.description}
                </p>
            </section>

            <!-- Strategy -->
            <section class="border-t border-editorial-surface-highest dark:border-editorial-surface-highest-dark pt-12">
                <h2 class="text-xs font-mono font-bold text-editorial-primary dark:text-editorial-primary-dark uppercase tracking-[0.3em] mb-8">Strategic Implementation</h2>
                <p class="text-editorial-secondary dark:text-editorial-secondary-dark leading-relaxed text-xl  font-light">
                    {project.details?.strategy || "Strategic approach details coming soon."}
                </p>
            </section>

            <!-- Implementation -->
            <section class="border-t border-editorial-surface-highest dark:border-editorial-surface-highest-dark pt-12">
                <h2 class="text-xs font-mono font-bold text-editorial-primary dark:text-editorial-primary-dark uppercase tracking-[0.3em] mb-8">Protocol Execution</h2>
                <ul class="space-y-6">
                    {project.details?.implementation?.map((item) => (
                        <li class="flex items-start gap-6 text-editorial-secondary dark:text-editorial-secondary-dark leading-relaxed text-lg  font-light ">
                            <span class="mt-3 w-8 h-[1px] bg-editorial-primary dark:bg-editorial-primary-dark flex-shrink-0"></span>
                            <span>{item}</span>
                        </li>
                    )) || <li>Implementation details coming soon.</li>}
                </ul>
            </section>

            {project.details?.reflection && (
                <section class="border-t border-editorial-surface-highest dark:border-editorial-surface-highest-dark pt-12">
                    <h2 class="text-xs font-mono font-bold text-editorial-primary dark:text-editorial-primary-dark uppercase tracking-[0.3em] mb-8">Professional Reflection</h2>
                    <p class="text-editorial-secondary dark:text-editorial-secondary-dark leading-relaxed text-xl  font-light  bg-editorial-surface-low dark:bg-editorial-surface-low-dark p-8 border-l-2 border-editorial-primary dark:border-editorial-primary-dark">
                        "{project.details.reflection}"
                    </p>
                </section>
            )}

            {project.details?.future && (
                <section class="border-t border-editorial-surface-highest dark:border-editorial-surface-highest-dark pt-12 pb-12">
                    <h2 class="text-xs font-mono font-bold text-editorial-primary dark:text-editorial-primary-dark uppercase tracking-[0.3em] mb-8">Future Scalability</h2>
                    <p class="text-editorial-secondary dark:text-editorial-secondary-dark leading-relaxed text-lg  font-light">
                        {project.details.future}
                    </p>
                </section>
            )}

        </div>

        <!-- Sidebar / Metrics -->
        <div class="lg:col-span-1">
            <div class="space-y-12 sticky top-32">
                <!-- Metrics -->
                <div class="bg-editorial-surface-low dark:bg-editorial-surface-low-dark p-8 border border-editorial-surface-highest dark:border-editorial-surface-highest-dark">
                    <h3 class="text-xs font-mono font-bold text-editorial-text dark:text-editorial-text-dark mb-10 uppercase tracking-[0.3em] border-b border-editorial-surface-highest dark:border-editorial-surface-highest-dark pb-6">Operational Impact</h3>
                    
                    <div class="space-y-10">
                        {project.details?.metrics?.map((metric) => (
                            <div class="group">
                                <p class="text-[10px] font-mono uppercase tracking-[0.2em] text-editorial-secondary dark:text-editorial-secondary-dark mb-3 group-hover:text-editorial-primary dark:group-hover:text-editorial-primary-dark transition-colors">{metric.label}</p>
                                <div class="space-y-2">
                                    <span class="block text-4xl font-bold text-editorial-text dark:text-editorial-text-dark   tracking-tighter leading-none">{metric.value}</span>
                                    {metric.change && (
                                        <span class="inline-block text-[9px] font-mono font-bold text-editorial-primary dark:text-editorial-primary-dark bg-editorial-primary/5 dark:bg-editorial-primary-dark/10 px-2 py-1 tracking-[0.15em] uppercase">
                                            {metric.change}
                                        </span>
                                    )}
                                </div>
                            </div>
                        )) || <p class="text-editorial-secondary dark:text-editorial-secondary-dark font-mono text-xs uppercase tracking-widest">Awaiting Metric Verification...</p>}
                    </div>
                </div>
                <!-- Tech Stack -->
                <div class="bg-editorial-surface-low dark:bg-editorial-surface-low-dark p-8 border border-editorial-surface-highest dark:border-editorial-surface-highest-dark">
                    <h3 class="text-xs font-mono font-bold text-editorial-text dark:text-editorial-text-dark mb-10 uppercase tracking-[0.3em] border-b border-editorial-surface-highest dark:border-editorial-surface-highest-dark pb-6">Technical Stack</h3>
                    <div class="flex flex-wrap gap-2">
                        {project.tags.map((tag) => (
                            <span class="px-3 py-1 bg-editorial-surface-highest dark:bg-editorial-surface-highest-dark text-editorial-text dark:text-editorial-text-dark text-[9px] font-mono font-bold uppercase tracking-[0.1em]">
                                {tag}
                            </span>
                        ))}
                    </div>
                </div>
            </div>
        </div>
      </div>

      <!-- Footer Action -->
      <div class="mt-32 pt-16 border-t border-editorial-surface-highest dark:border-editorial-surface-highest-dark text-center">
        <a 
          href="/#projects" 
          class="inline-flex items-center px-12 py-5 bg-editorial-text dark:bg-editorial-primary-dark text-editorial-surface dark:text-editorial-surface-dark font-mono text-xs font-bold uppercase tracking-[0.3em] hover:bg-editorial-primary dark:hover:bg-editorial-text-dark transition-all duration-300"
        >
          Exit Technical Overview
        </a>
      </div>

    </div>
  </main>
</Layout>
